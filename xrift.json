{
  "world": {
    "distDir": "./dist",
    "title": "Luna Atlas",
    "description": "Shared lunar observatory with a central moon, an equator viewing deck, and synchronized direct rotation and scale interaction. Lunar color and elevation textures adapted from NASA's Scientific Visualization Studio CGI Moon Kit, visualized by Ernie Wright, using LRO LOLA and LROC WAC mosaic data.",
    "thumbnailPath": "moon-thumbnail.jpg",
    "buildCommand": "npm run build",
    "ignore": [
      "**/.DS_Store",
      "**/Thumbs.db",
      "**/*.js.map",
      "**/.gitkeep",
      "**/index.html",
      "**/__federation_shared_@react-three/drei-*.js",
      "**/__federation_shared_@react-three/fiber-*.js",
      "**/__federation_shared_@react-three/rapier-*.js",
      "**/__federation_shared_@xrift/world-components-*.js",
      "**/__federation_shared_three-*.js",
      "**/__federation_shared_react-*.js",
      "**/__federation_shared_react-dom-*.js",
      "**/__federation_shared_react-dom/client-*.js",
      "**/__federation_shared_react/jsx-runtime-*.js",
      "**/rapier.es-*.js",
      "**/hls-*.js"
    ],
    "physics": {
      "gravity": 1.635,
      "allowInfiniteJump": false
    },
    "camera": {
      "near": 0.02,
      "far": 1800
    }
  }
}
